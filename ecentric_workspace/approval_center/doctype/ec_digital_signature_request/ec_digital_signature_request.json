{
 "doctype": "DocType",
 "name": "EC Digital Signature Request",
 "module": "Approval Center",
 "custom": 0,
 "istable": 0,
 "issingle": 0,
 "is_virtual": 0,
 "editable_grid": 1,
 "engine": "InnoDB",
 "track_changes": 1,
 "allow_rename": 0,
 "sort_field": "modified",
 "sort_order": "DESC",
 "links": [],
 "index_web_pages_for_search": 0,
 "autoname": "EC-DSR-.YYYY.-.#####.",
 "naming_rule": "Expression",
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "email": 1,
   "export": 1,
   "print": 1,
   "report": 1,
   "share": 1
  }
 ],
 "field_order": [
  "provider",
  "environment",
  "package",
  "approval_request",
  "request_level",
  "approver_row",
  "action",
  "transition_id",
  "requested_by",
  "approver",
  "effective_scts_user_id",
  "effective_signature_id",
  "idempotency_key",
  "status",
  "bulk_job_transaction_id",
  "bulk_batch_key",
  "package_version",
  "package_hash",
  "request_attempt",
  "queued_at",
  "accepted_at",
  "verified_at",
  "completed_at",
  "error_code",
  "error_message",
  "retryable",
  "provider_sync_pending",
  "manual_review_reason"
 ],
 "fields": [
  {
   "fieldname": "provider",
   "fieldtype": "Select",
   "label": "Provider",
   "options": "SCTS\nMock"
  },
  {
   "fieldname": "environment",
   "fieldtype": "Select",
   "label": "Environment",
   "options": "UAT\nProduction"
  },
  {
   "fieldname": "package",
   "fieldtype": "Link",
   "label": "Package",
   "options": "EC Digital Signature Package",
   "reqd": 1
  },
  {
   "fieldname": "approval_request",
   "fieldtype": "Link",
   "label": "Approval Request",
   "options": "EC Approval Request",
   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "request_level",
   "fieldtype": "Link",
   "label": "Request Level",
   "options": "EC Approval Request Level",
   "reqd": 0
  },
  {
   "fieldname": "approver_row",
   "fieldtype": "Link",
   "label": "Approver Row",
   "options": "EC Approval Request Approver",
   "reqd": 0
  },
  {
   "fieldname": "actor_type",
   "fieldtype": "Select",
   "options": "Approval Level\nRequester",
   "default": "Approval Level",
   "label": "Actor Type",
   "description": "Approval Level = a frozen runtime approver signing a level (request_level+approver_row required). Requester = pre-approval requester signing (request_level/approver_row not used)."
  },
  {
   "fieldname": "actor_user",
   "fieldtype": "Link",
   "options": "User",
   "label": "Actor User"
  },
  {
   "fieldname": "action",
   "fieldtype": "Select",
   "label": "Action",
   "options": "Sign\nReject\nCancel",
   "default": "Sign",
   "reqd": 1
  },
  {
   "fieldname": "transition_id",
   "fieldtype": "Int",
   "label": "Transition Id"
  },
  {
   "fieldname": "requested_by",
   "fieldtype": "Link",
   "label": "ERP Actor",
   "options": "User",
   "reqd": 1,
   "description": "Authenticated ERP session user who initiated this action."
  },
  {
   "fieldname": "approver",
   "fieldtype": "Link",
   "label": "Expected Approver",
   "options": "User",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "effective_scts_user_id",
   "fieldtype": "Data",
   "label": "Effective Scts User Id",
   "read_only": 1
  },
  {
   "fieldname": "effective_signature_id",
   "fieldtype": "Data",
   "label": "Effective Signature Id",
   "read_only": 1
  },
  {
   "fieldname": "idempotency_key",
   "fieldtype": "Data",
   "label": "Idempotency Key",
   "unique": 1,
   "reqd": 1,
   "read_only": 1,
   "length": 64
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Draft\nPrepared\nQueued\nProvider Accepted\nVerifying\nSigned\nApproval Completed\nMapping Required\nPlacement Required\nRetryable Failure\nPermanent Failure\nVerification Mismatch\nManual Review\nCancelled\nRejected\nSuperseded",
   "default": "Draft",
   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "bulk_job_transaction_id",
   "fieldtype": "Data",
   "label": "Bulk Job Transaction Id"
  },
  {
   "fieldname": "bulk_batch_key",
   "fieldtype": "Data",
   "label": "Bulk Batch Key"
  },
  {
   "fieldname": "package_version",
   "fieldtype": "Int",
   "label": "Package Version",
   "read_only": 1
  },
  {
   "fieldname": "package_hash",
   "fieldtype": "Data",
   "label": "Package Hash",
   "read_only": 1,
   "length": 64
  },
  {
   "fieldname": "request_attempt",
   "fieldtype": "Int",
   "label": "Request Attempt",
   "default": "1"
  },
  {
   "fieldname": "queued_at",
   "fieldtype": "Datetime",
   "label": "Queued At",
   "read_only": 1
  },
  {
   "fieldname": "accepted_at",
   "fieldtype": "Datetime",
   "label": "Accepted At",
   "read_only": 1
  },
  {
   "fieldname": "verified_at",
   "fieldtype": "Datetime",
   "label": "Verified At",
   "read_only": 1
  },
  {
   "fieldname": "completed_at",
   "fieldtype": "Datetime",
   "label": "Completed At",
   "read_only": 1
  },
  {
   "fieldname": "error_code",
   "fieldtype": "Data",
   "label": "Error Code"
  },
  {
   "fieldname": "error_message",
   "fieldtype": "Small Text",
   "label": "Error Message"
  },
  {
   "fieldname": "retryable",
   "fieldtype": "Check",
   "label": "Retryable",
   "default": "0"
  },
  {
   "fieldname": "provider_sync_pending",
   "fieldtype": "Check",
   "label": "Provider Sync Pending",
   "default": "0"
  },
  {
   "fieldname": "manual_review_reason",
   "fieldtype": "Small Text",
   "label": "Manual Review Reason"
  }
 ]
}