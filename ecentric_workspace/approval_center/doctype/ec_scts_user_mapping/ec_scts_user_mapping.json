  {
   "fieldname": "verified_by",
   "fieldtype": "Link",
   "label": "Verified By",
   "options": "User",
   "read_only": 1
  },
  {
   "fieldname": "signature_meta_summary",
   "fieldtype": "Data",
   "label": "Signature Meta Summary",
   "read_only": 1,
   "description": "Safe metadata only (type/company). Never signature images, never HSM IDs."
  },
  {
   "fieldname": "notes",
   "fieldtype": "Small Text",
   "label": "Notes"
  }
 ]
}
