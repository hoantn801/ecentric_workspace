   "create": 1,
   "delete": 1,
   "email": 1,
   "export": 1,
   "print": 1,
   "report": 1,
   "share": 1
  }
 ],
 "field_order": [
  "frappe_user",
  "environment",
  "scts_user_id",
  "signature_id",
  "signature_type",
  "company_id",
  "active",
  "mapping_status",
  "verified_at",
  "verified_by",
  "signature_meta_summary",
  "notes"
 ],
 "fields": [
