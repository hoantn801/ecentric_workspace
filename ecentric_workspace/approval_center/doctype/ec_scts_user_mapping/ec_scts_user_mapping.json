   "label": "Environment",
   "options": "UAT\nProduction",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "scts_user_id",
   "fieldtype": "Data",
   "label": "SCTS User ID",
   "reqd": 1
  },
  {
   "fieldname": "signature_id",
   "fieldtype": "Data",
   "label": "SCTS Signature ID",
   "reqd": 1
  },
  {
   "fieldname": "signature_type",
   "fieldtype": "Data",
   "label": "Signature Type"
  },
  {
   "fieldname": "company_id",
   "fieldtype": "Data",
   "label": "SCTS Company ID"
  },
  {
   "fieldname": "active",
   "fieldtype": "Check",
   "label": "Active",
   "default": "1",
   "in_list_view": 1
  },
  {
   "fieldname": "mapping_status",
   "fieldtype": "Select",
   "label": "Mapping Status",
   "options": "Draft\nVerified\nSuspended",
   "default": "Draft",
   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "verified_at",
