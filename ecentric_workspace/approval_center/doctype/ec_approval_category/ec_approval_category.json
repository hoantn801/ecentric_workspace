{
 "doctype": "DocType",
 "name": "EC Approval Category",
 "module": "Approval Center",
 "custom": 0,
 "istable": 0,
 "issingle": 0,
 "is_virtual": 0,
 "editable_grid": 1,
 "engine": "InnoDB",
 "track_changes": 1,
 "allow_rename": 0,
 "naming_rule": "By fieldname",
 "autoname": "field:category_code",
 "sort_field": "sort_order",
 "sort_order": "ASC",
 "title_field": "category_name",
 "field_order": [
  "category_code",
  "category_name",
  "icon",
  "sort_order",
  "is_active"
 ],
 "fields": [
  {
   "fieldname": "category_code",
   "fieldtype": "Data",
   "label": "Category Code",
   "reqd": 1,
   "unique": 1,
   "set_only_once": 1,
   "in_list_view": 1,
   "description": "UPPER_SNAKE immutable code. Used as docname and as the Link key from EC Approval Type."
  },
  {
   "fieldname": "category_name",
   "fieldtype": "Data",
   "label": "Category Name",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "icon",
   "fieldtype": "Data",
   "label": "Icon",
   "description": "Icon key (lucide/feather) rendered by the frontend in a later phase."
  },
  {
   "fieldname": "sort_order",
   "fieldtype": "Int",
   "label": "Sort Order",
   "default": "0",
   "in_list_view": 1
  },
  {
   "fieldname": "is_active",
   "fieldtype": "Check",
   "label": "Is Active",
   "default": "1",
   "in_list_view": 1
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "email": 1,
   "export": 1,
   "print": 1,
   "report": 1,
   "share": 1
  }
 ],
 "links": [],
 "index_web_pages_for_search": 0
}
