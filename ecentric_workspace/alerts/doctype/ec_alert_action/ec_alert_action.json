  {
   "fieldname": "available_stock_before",
   "fieldtype": "Float",
   "label": "Available Stock Before",
   "read_only": 1
  },
  {
   "fieldname": "buffer_stock_before",
   "fieldtype": "Float",
   "label": "Buffer Stock Before",
   "read_only": 1
  },
  {
   "fieldname": "cb_ds1",
   "fieldtype": "Column Break",
   "label": ""
  },
  {
   "fieldname": "buffer_stock_after",
   "fieldtype": "Float",
   "label": "Buffer Stock After",
   "read_only": 1
  },
  {
   "fieldname": "locked_quantity",
   "fieldtype": "Float",
   "label": "Locked Quantity",
   "read_only": 1
  },
  {
   "fieldname": "release_required",
   "fieldtype": "Check",
   "label": "Release Required",
   "default": "0"
  },
  {
   "fieldname": "release_strategy",
   "fieldtype": "Select",
   "label": "Release Strategy",
   "options": "\nRestore Previous Buffer\nReduce By Locked Quantity\nManual"
