  {
   "fieldname": "cb_2",
   "fieldtype": "Column Break",
   "label": ""
  },
  {
   "fieldname": "api_response",
   "fieldtype": "Small Text",
   "label": "API Response",
   "description": "Sanitized response only. Never store credentials or auth headers here."
  },
  {
   "fieldname": "error_message",
   "fieldtype": "Small Text",
   "label": "Error Message"
  },
  {
   "fieldname": "dedupe_key",
   "fieldtype": "Data",
   "label": "Dedupe Key",
   "unique": 1,
   "read_only": 1,
   "description": "omisell|{external_order_id}|{external_line_id}|stock_safety_lock|{rule_code}"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "email": 1,
   "export": 1,
   "print": 1,
   "report": 1,
   "share": 1
  }
 ],
