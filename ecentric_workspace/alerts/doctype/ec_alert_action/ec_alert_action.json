 "fields": [
  {
   "fieldname": "alert",
   "fieldtype": "Link",
   "label": "Alert",
   "options": "EC Alert",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "action_type",
   "fieldtype": "Select",
   "label": "Action Type",
   "options": "Notify Only\nStock Safety Lock\nRelease Stock Safety Lock",
   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1,
   "description": "No Off Listing / price-change action exists by design. Stock Safety Lock only holds inventory / sets available stock to 0."
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Pending\nProcessing\nSuccess\nFailed\nCancelled\nSkipped\nDry Run",
   "default": "Pending",
   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "cb_0",
   "fieldtype": "Column Break",
   "label": ""
  },
  {
   "fieldname": "source_system",
   "fieldtype": "Select",
   "label": "Source System",
   "options": "Omisell",
   "default": "Omisell"
  },
  {
   "fieldname": "brand",
   "fieldtype": "Link",
   "label": "Brand",
   "options": "Brand Approver",
   "reqd": 1,
   "in_standard_filter": 1,
   "description": "Credential lookup key: execution loads EC Brand Integration Settings of THIS brand only. No cross-brand credential reuse."
  },
  {
   "fieldname": "platform",
   "fieldtype": "Select",
   "label": "Platform",
   "options": "Shopee\nLazada\nTikTok\nOther"
  },
  {
   "fieldname": "shop",
   "fieldtype": "Link",
   "label": "Shop",
   "options": "EC Marketplace Shop"
  },
  {
   "fieldname": "sec_target",
   "fieldtype": "Section Break",
   "label": "Target"
  },
  {
   "fieldname": "item",
   "fieldtype": "Link",
   "label": "Item",
   "options": "Item"
  },
  {
   "fieldname": "seller_sku",
   "fieldtype": "Data",
   "label": "Seller SKU",
   "in_list_view": 1
  },
  {
   "fieldname": "external_product_id",
   "fieldtype": "Data",
   "label": "External Product ID"
  },
  {
   "fieldname": "cb_1",
   "fieldtype": "Column Break",
   "label": ""
  },
  {
   "fieldname": "previous_available_stock",
   "fieldtype": "Float",
   "label": "Previous Available Stock",
   "read_only": 1
  },
  {
   "fieldname": "lock_until",
   "fieldtype": "Datetime",
   "label": "Lock Until"
  },
  {
   "fieldname": "lock_reason",
   "fieldtype": "Small Text",
   "label": "Lock Reason"
  },
  {
   "fieldname": "sec_exec",
   "fieldtype": "Section Break",
   "label": "Execution"
  },
  {
   "fieldname": "requested_at",
   "fieldtype": "Datetime",
   "label": "Requested At",
   "read_only": 1
  },
  {
   "fieldname": "executed_at",
   "fieldtype": "Datetime",
   "label": "Executed At",
   "read_only": 1
  },
  {
   "fieldname": "executed_by",
   "fieldtype": "Link",
   "label": "Executed By",
   "options": "User",
   "read_only": 1
  },
  {
   "fieldname": "release_status",
   "fieldtype": "Select",
   "label": "Release Status",
   "options": "Not Required\nPending\nReleased\nFailed",
   "default": "Not Required"
