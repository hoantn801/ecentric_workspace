{
 "doctype": "DocType",
 "name": "EC Order Retry",
 "module": "Alerts",
 "custom": 0,
 "istable": 0,
 "issingle": 0,
 "editable_grid": 0,
 "engine": "InnoDB",
 "track_changes": 1,
 "allow_rename": 0,
 "autoname": "format:EC-ORT-{######}",
 "naming_rule": "Expression",
 "sort_field": "next_retry_at",
 "sort_order": "ASC",
 "field_order": [
  "retry_key",
  "brand",
  "source",
  "order_number",
  "cb_0",
  "status",
  "attempt_count",
  "max_attempts",
  "trigger_source",
  "processing_token",
  "processing_started_at",
  "sec_err",
  "error_type",
  "error_code",
  "last_error",
  "sec_time",
  "next_retry_at",
  "first_failed_at",
  "cb_1",
  "last_attempt_at",
  "completed_at"
 ],
 "fields": [
  {"fieldname": "retry_key", "fieldtype": "Data", "label": "Retry Key", "unique": 1, "read_only": 1, "length": 200, "in_list_view": 1, "description": "source|brand|order_number (idempotent upsert identity)."},
  {"fieldname": "brand", "fieldtype": "Link", "label": "Brand", "options": "Brand Approver", "in_list_view": 1, "in_standard_filter": 1, "search_index": 1},
  {"fieldname": "source", "fieldtype": "Select", "label": "Source", "options": "Omisell\nERP\nManual", "default": "Omisell"},
  {"fieldname": "order_number", "fieldtype": "Data", "label": "Order Number", "in_list_view": 1, "search_index": 1},
  {"fieldname": "cb_0", "fieldtype": "Column Break"},
  {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Pending\nProcessing\nCompleted\nDead", "default": "Pending", "in_list_view": 1, "in_standard_filter": 1, "search_index": 1},
  {"fieldname": "attempt_count", "fieldtype": "Int", "label": "Attempt Count", "read_only": 1},
  {"fieldname": "max_attempts", "fieldtype": "Int", "label": "Max Attempts", "read_only": 1},
  {"fieldname": "trigger_source", "fieldtype": "Select", "label": "Trigger Source", "options": "Pull Failure\nScheduler\nManual", "default": "Pull Failure", "read_only": 1},
  {"fieldname": "processing_token", "fieldtype": "Data", "label": "Processing Token", "read_only": 1, "description": "Per-claim lock token; only the holder may transition the item."},
  {"fieldname": "processing_started_at", "fieldtype": "Datetime", "label": "Processing Started At", "read_only": 1, "description": "When the current claim began (stale-recovery threshold)."},
  {"fieldname": "sec_err", "fieldtype": "Section Break", "label": "Error"},
  {"fieldname": "error_type", "fieldtype": "Data", "label": "Error Type", "read_only": 1},
  {"fieldname": "error_code", "fieldtype": "Data", "label": "Error Code", "read_only": 1},
  {"fieldname": "last_error", "fieldtype": "Small Text", "label": "Last Error", "read_only": 1, "description": "Sanitized + truncated; NEVER contains tokens/credentials/headers/payloads."},
  {"fieldname": "sec_time", "fieldtype": "Section Break", "label": "Schedule"},
  {"fieldname": "next_retry_at", "fieldtype": "Datetime", "label": "Next Retry At", "read_only": 1, "search_index": 1},
  {"fieldname": "first_failed_at", "fieldtype": "Datetime", "label": "First Failed At", "read_only": 1},
  {"fieldname": "cb_1", "fieldtype": "Column Break"},
  {"fieldname": "last_attempt_at", "fieldtype": "Datetime", "label": "Last Attempt At", "read_only": 1},
  {"fieldname": "completed_at", "fieldtype": "Datetime", "label": "Completed At", "read_only": 1}
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "email": 1, "export": 1, "print": 1, "report": 1, "share": 1}
 ],
 "links": [],
 "index_web_pages_for_search": 0
}
