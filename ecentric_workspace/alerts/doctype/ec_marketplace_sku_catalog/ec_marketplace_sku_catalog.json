{
 "doctype": "DocType",
 "name": "EC Marketplace SKU Catalog",
 "module": "Alerts",
 "custom": 0,
 "istable": 0,
 "issingle": 0,
 "is_virtual": 0,
 "editable_grid": 1,
 "engine": "InnoDB",
 "track_changes": 0,
 "allow_rename": 0,
 "allow_import": 1,
 "autoname": "format:EC-SKU-{######}",
 "naming_rule": "Expression",
 "sort_field": "last_seen_at",
 "sort_order": "DESC",
 "field_order": [
  "brand",
  "platform",
  "shop",
  "omisell_shop_id",
  "cb_0",
  "seller_sku",
  "product_name",
  "external_product_id",
  "erpnext_item_code",
  "sec_price",
  "rsp_price",
  "is_active",
  "status",
  "cb_1",
  "source_system",
  "source_level",
  "first_seen_at",
  "last_seen_at",
  "sec_meta",
  "raw_payload_hash",
  "catalog_key",
  "note"
 ],
 "fields": [
  {"fieldname": "brand", "fieldtype": "Link", "label": "Brand", "options": "Brand Approver", "in_list_view": 1, "in_standard_filter": 1, "search_index": 1},
  {"fieldname": "platform", "fieldtype": "Select", "label": "Platform", "options": "Shopee\nLazada\nTikTok\nOther", "in_list_view": 1, "in_standard_filter": 1},
  {"fieldname": "shop", "fieldtype": "Link", "label": "Shop", "options": "EC Marketplace Shop", "in_standard_filter": 1},
  {"fieldname": "omisell_shop_id", "fieldtype": "Data", "label": "Omisell Shop ID", "search_index": 1},
  {"fieldname": "cb_0", "fieldtype": "Column Break"},
  {"fieldname": "seller_sku", "fieldtype": "Data", "label": "Seller SKU", "in_list_view": 1, "in_standard_filter": 1, "search_index": 1},
  {"fieldname": "product_name", "fieldtype": "Data", "label": "Product Name", "in_list_view": 1},
  {"fieldname": "external_product_id", "fieldtype": "Data", "label": "External Product ID"},
  {"fieldname": "erpnext_item_code", "fieldtype": "Link", "label": "ERPNext Item", "options": "Item"},
  {"fieldname": "sec_price", "fieldtype": "Section Break", "label": "Price & status"},
  {"fieldname": "rsp_price", "fieldtype": "Currency", "label": "RSP / Listed Price", "in_list_view": 1, "description": "Latest list_price (Omisell original_price) seen on an order line for this SKU."},
  {"fieldname": "is_active", "fieldtype": "Check", "label": "Is Active", "default": "1"},
  {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Active\nStale\nRetired", "default": "Active"},
  {"fieldname": "cb_1", "fieldtype": "Column Break"},
  {"fieldname": "source_system", "fieldtype": "Select", "label": "Source System", "options": "Omisell\nERP\nManual", "default": "Omisell"},
  {"fieldname": "source_level", "fieldtype": "Select", "label": "Source Level", "options": "order_derived\nomisell_product", "default": "order_derived"},
  {"fieldname": "first_seen_at", "fieldtype": "Datetime", "label": "First Seen At", "read_only": 1},
  {"fieldname": "last_seen_at", "fieldtype": "Datetime", "label": "Last Seen At", "read_only": 1, "search_index": 1},
  {"fieldname": "sec_meta", "fieldtype": "Section Break", "label": "Meta"},
  {"fieldname": "raw_payload_hash", "fieldtype": "Data", "label": "Raw Payload Hash", "read_only": 1},
  {"fieldname": "catalog_key", "fieldtype": "Data", "label": "Catalog Key", "unique": 1, "read_only": 1, "length": 140, "description": "source_system|omisell_shop_id|seller_sku (upsert identity)."},
  {"fieldname": "note", "fieldtype": "Small Text", "label": "Note"}
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "email": 1, "export": 1, "print": 1, "report": 1, "share": 1}
 ],
 "links": [],
 "index_web_pages_for_search": 0
}
